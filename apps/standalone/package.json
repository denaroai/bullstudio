{
  "name": "@bullstudio/standalone",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "esbuild server/production.ts --bundle --platform=node --target=node20 --outfile=dist/server/production.js --format=esm --external:bull --external:bullmq --external:ioredis",
    "start": "node dist/server/production.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint"
  },
  "dependencies": {
    "@bullstudio/bull-adapter": "workspace:*",
    "@bullstudio/bullmq-adapter": "workspace:*",
    "@bullstudio/connect-types": "workspace:*",
    "@bullstudio/embedded-core": "workspace:*",
    "@bullstudio/private-router": "workspace:*",
    "@hono/node-server": "^2.0.4",
    "@trpc/server": "^11.4.3",
    "bull": "^4.16.4",
    "bullmq": "^5.34.8",
    "hono": "^4.12.23",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@bullstudio/typescript-config": "workspace:*",
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}

{
  "name": "@bullstudio/website-with-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-sitemap.mjs && react-router build",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "dev": "react-router dev",
    "start": "serve ./build/client --config ../../serve.json",
    "typecheck": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "lint": "biome lint .",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@posthog/react": "^1.10.2",
    "@react-router/node": "^7.15.1",
    "fumadocs-core": "16.10.5",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-ui": "16.10.5",
    "isbot": "^5.1.43",
    "lucide-react": "^1.20.0",
    "posthog-js": "^1.391.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.15.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.15.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react-router-devtools": "^6.2.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}

{
  "name": "bullstudio",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test --concurrency=1",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "pack:check": "node scripts/verify-public-packs.mjs",
    "format": "biome format --write .",
    "check": "biome lint ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@bullstudio/typescript-config": "workspace:*",
    "@changesets/cli": "^2.31.0",
    "tsup": "^8.5.1",
    "turbo": "^2.6.3",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "@types/react": "19.1.9",
      "@types/react-dom": "19.1.7",
      "csstype": "3.1.3"
    }
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@types/dagre": "^0.7.53",
    "dagre": "^0.8.5"
  }
}

{
  "name": "bullstudio",
  "version": "1.5.0",
  "description": "A lightweight queue management dashboard for Bull and BullMQ",
  "private": false,
  "type": "module",
  "bin": {
    "bullstudio": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "bullmq",
    "bull",
    "queue",
    "redis",
    "dashboard",
    "cli",
    "monitoring",
    "jobs"
  ],
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emirce/bullstudio.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/emirce/bullstudio/issues"
  },
  "homepage": "https://github.com/emirce/bullstudio#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm --filter @bullstudio/frontend build && pnpm --filter @bullstudio/embedded-core build && pnpm --filter @bullstudio/bull-adapter build && pnpm --filter @bullstudio/bullmq-adapter build && pnpm --filter @bullstudio/standalone build && rm -rf dist/client dist/server && mkdir -p dist/client dist/server && cp -R ../../apps/frontend/dist/client/. dist/client/ && cp ../../apps/standalone/dist/server/production.js dist/server/production.js && pnpm build:cli",
    "build:cli": "esbuild index.ts --bundle --platform=node --target=node20 --outfile=dist/bin/cli.js --format=esm --external:open",
    "start": "node dist/bin/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "prepublishOnly": "pnpm build",
    "generate:bull-jobs": "tsx scripts/generate-bull-jobs.ts",
    "seed:demo": "tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "bull": "^4.16.4",
    "bullmq": "^5.34.8",
    "ioredis": "^5.4.2",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@bullstudio/typescript-config": "workspace:*",
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2"
  }
}

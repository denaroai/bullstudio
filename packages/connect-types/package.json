{
  "name": "@bullstudio/connect-types",
  "version": "2.0.1",
  "description": "Shared TypeScript contracts for Bullstudio queue adapter authors.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "bullstudio",
    "types",
    "adapter",
    "bullmq",
    "bull",
    "queue"
  ],
  "homepage": "https://github.com/emirce/bullstudio#readme",
  "bugs": {
    "url": "https://github.com/emirce/bullstudio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emirce/bullstudio.git",
    "directory": "packages/connect-types"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },

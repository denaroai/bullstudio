{
  "name": "@bullstudio/next",
  "version": "2.0.1",
  "description": "Next.js App Router framework adapter for Bullstudio embedded mode.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "bullstudio",
    "bullmq",
    "bull",
    "nextjs",
    "dashboard",
    "queue"
  ],
  "homepage": "https://github.com/emirce/bullstudio#readme",
  "bugs": {
    "url": "https://github.com/emirce/bullstudio/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emirce/bullstudio.git",
    "directory": "packages/next-adapter"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "biome lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0"
  },
  "dependencies": {
    "@bullstudio/embedded-core": "workspace:*"
  },
  "devDependencies": {
    "@bullstudio/typescript-config": "workspace:*",
    "@types/node": "^24.10.1",
    "next": "^16.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
